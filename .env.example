# ============================================================
# Hype Scout v2 — Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================

# ── Helius RPC (for holder count — get free key at helius.dev) ──────────────
HELIUS_API_KEY=YOUR_HELIUS_API_KEY_HERE

# ── Discord Bot Token & Channels ──────────────────────────────────────────────
# Bot must be in your server with "Send Messages" permission in both channels.
DISCORD_BOT_TOKEN=YOUR_DISCORD_BOT_TOKEN_HERE
DISCORD_EARLY_TRENDING_CHANNEL=1477161564460159097
DISCORD_RUNNERS_CHANNEL=1477453762959249559

# ── Telegram Bot ──────────────────────────────────────────────────────────────
# Create a bot via @BotFather on Telegram, then paste the token here.
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
# Optional: one-way channel ID (e.g. @HypeScoutAlerts or -100xxxxxxxxxx)
TELEGRAM_CHANNEL_ID=

# ── Scanner Thresholds ────────────────────────────────────────────────────────
MC_MIN_USD=5000
MC_MAX_USD=60000
BC_MAX_PCT=85
MIN_SOL_LIQ=0.5
MIN_HOLDERS=10

# ── Runtime ───────────────────────────────────────────────────────────────────
POLL_INTERVAL=30
POSTER_SLEEP=10
MAX_POST_PER_RUN=3
TRACK_MAX_AGE_HOURS=24
TIER_COOLDOWN_MIN=30
